.build/
.swiftpm/
*.xcuserstate
xcuserdata/
.DS_Store
Drott.app/

# Python AlphaZero side
python/.venv/
python/__pycache__/
# generated parity oracle (~33 MB); regenerate via DROTT_DUMP_CORPUS=1
python/parity_corpus.json
*.pyc

# third-party AlphaZero framework (local dev dependency; not our code)
alpha-zero-general-master/
python/temp/          # training checkpoints
*.pth.tar
*.examples

# published Astrid models are local artifacts (~22 MB each). The baseline
# Astrid_v0 is committed so the app builds out of the box; nets you publish
# later (Astrid_v1, v2, …) stay local — back them up alongside python/temp/.
Sources/Drott/models/*.mlpackage
!Sources/Drott/models/Astrid_v0.mlpackage
