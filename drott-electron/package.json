{
  "name": "drott",
  "version": "1.0.0",
  "description": "Drott — a Norse strategy game",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "bun test",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "onnxruntime-node": "^1.27.0"
  },
  "build": {
    "appId": "com.emildanielsen.drott",
    "productName": "Drott",
    "asar": true,
    "asarUnpack": [
      "node_modules/onnxruntime-node/**"
    ],
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "board-state.js",
      "drott-rules.js",
      "herringbone-ai.js",
      "herringbone-fork.js",
      "onnx-ai.js",
      "astrid-fork.js",
      "hud.js",
      "sound.js",
      "game.js",
      "renderer.js",
      "ai-dispatch.js",
      "rules-page.js",
      "sandbox.js",
      "assets/**",
      "onnx_models/**",
      "!onnx_models/astrid_it*.onnx",
      "node_modules/**",
      "!node_modules/.cache/**",
      "!**/*.test.js"
    ],
    "mac": {
      "icon": "assets/drott.icns",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.games",
      "identity": "EMIL DANIELSEN (3FY4D2C459)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Game"
    },
    "dmg": {
      "title": "Drott"
    }
  }
}
